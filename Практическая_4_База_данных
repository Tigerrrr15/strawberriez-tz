6. Индексы для производительности

-- Для быстрого поиска по категории
CREATE INDEX idx_products_category ON products(category_id);

-- Для фильтрации по цене
CREATE INDEX idx_products_price ON products(price);

-- Для поиска по названию
CREATE INDEX idx_products_name_trgm ON products USING GIN (name gin_trgm_ops);

-- Для полнотекстового поиска
CREATE INDEX idx_products_search ON products USING GIN (to_tsvector('russian', name));

-- Для сортировки по новизне
CREATE INDEX idx_products_created_at ON products(created_at DESC);

-- Для корзины (поиск корзины пользователя)
CREATE INDEX idx_carts_user_id ON carts(user_id);
CREATE INDEX idx_carts_session_id ON carts(session_id);

-- Для позиций корзины
CREATE INDEX idx_cart_items_cart ON cart_items(cart_id);

